# PRP device config: OPPO A16 (MT6765)
#
# Initial bring-up profile:
# - use the known-good TWRP kernel
# - boot a unique PRP initramfs
# - keep runtime simple/headless until basic boot is stable

TARGET_NAME="oppo-a16"
BOARD_NAME=""
TARGET_ARCH="armv7"
IS_MSM="0"
IS_MSM_FB_REFRESHER="0"
IS_MSM_LK2ND_SPLIT_BOOT="0"

# Android boot image params derived from the current A16 boot image /
# TWRP device tree. Base + offsets match the known-good layout.
CMDLINE="console=tty0 console=ttyS0,921600n1 vmalloc=400M page_owner=on swiotlb=noforce androidboot.hardware=mt6765 maxcpus=8 loop.max_part=7 firmware_class.path=/vendor/firmware bootopt=64S3,32N2,64N2 buildvariant=user mtk_printk_ctrl.disable_uart=0 printk.force_uart=1"
BASE="0x40078000"
KERNEL_OFFSET="0x00008000"
RAMDISK_OFFSET="0x11a88000"
SECOND_OFFSET="0xbff88000"
TAGS_OFFSET="0x07808000"
PAGESIZE="2048"
HEADER_VERSION="2"
APPEND_SEANDROIDENFORCE="0"

# Known-good kernel from the working built TWRP recovery image.
KERNEL_IMAGE="$PRP_ROOT/../experiments/twrp/out/target/product/a16/kernel"
DTB_IMAGE="$PRP_ROOT/../boot_cur.img-dtb"

# Always build a unique PRP ramdisk for this profile.
RAMDISK_PREBUILT=""
RAMDISK_FORMAT="gzip"
INITRAMFS_ROOTFS="initramfs/rootfs"
ROOTFS_IMAGE="$HOME/.local/var/peacock/oppo-a16.img"
ROOTFS_OFFSET_SECTORS="1050624"
ROOTFS_SIZE_SECTORS="3141632"

# Kernel config is optional for bring-up checks, but keep the known local copy.
KERNEL_CONFIG="$PRP_ROOT/../.codex-tmp/twrp-kernel.config"

# Flash PRP to the dedicated recovery partition.
FLASH_METHOD="adb-dd"
ADB_PREFIX="adb"
RECOVERY_BLOCK="/dev/block/by-name/recovery"

# Do not require TWRP runtime blobs for the first initramfs bring-up.
REQUIRE_TWRP_SBIN="0"
USB_SERIAL="PRP-OPPO-A16"

# Keep the first boot path simple and debug-friendly.
DO_MOUNT_SUBPARTS="0"
MOUNT_PRP_ROOTFS="0"
PRP_MONOLITHIC_INITRAMFS="1"
ENABLE_FB_IO="1"
USE_FB_REFRESHER="0"
DEBUG_BOOT="0"
START_TTY_SHELLS="1"
TEXT_CONSOLE_LOG="1"
START_SSH="0"
SMOKE_ONLY="0"
DROPBEAR_PATCH_MODE="vanilla"
DROPBEAR_CC_MODE="muslcc"
DROPBEAR_OPT_LEVEL="0"

# A16 power key comes from the PMIC key device (mt6357/mtk-pmic-keys).
# Without an explicit device path PRP GUI can tie on scoring between
# `mtk-kpd` and `mtk-pmic-keys`, then select the wrong event node by scan order.
GUI_POWER_INPUT="/dev/input/event1"
GUI_POWER_HINT="mtk-pmic-keys mtk-kpd"
GUI_POWER_CODE="116"
