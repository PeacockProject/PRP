# PRP config for the QEMU x86_64 virtual target.
#
# Unlike the phone targets there's no lk2nd 16 MiB ramdisk cap, so PRP is built
# MONOLITHIC — the PRP_ROOTFS overlay (LVGL prp-gui, busybox, dropbear,
# prp-recovery-enter) is embedded directly in the initramfs. GRUB loads the
# kernel + this one initramfs; no separate recovery partition needed.
#
# Build:  make initramfs TARGET=qemu-x86_64
# Boot :  GRUB -> linux <vmlinuz> ; initrd <initramfs.cpio.gz>

TARGET_NAME="qemu-x86_64"
TARGET_ARCH="x86_64"
BOARD_NAME=""

# ZIG_TARGET defaults to x86_64-linux-musl (common.sh). Static-musl via zig, so
# no native-glibc static-libcrypt wall.

CMDLINE="console=ttyS0,115200 console=tty0 loglevel=7"
RAMDISK_FORMAT="gzip"
INITRAMFS_ROOTFS="initramfs/rootfs"

# A static busybox built with PRP's build-busybox-static.sh (zig musl). The
# Makefile / port sets this; default to the manual build location.
BUSYBOX_STATIC="${BUSYBOX_STATIC:-/tmp/prp-bb-x86}"

# Generic x86_64 kernel (only used by `make bootimg`, which we don't run for
# QEMU — GRUB supplies the kernel). Kept for completeness.
KERNEL_IMAGE="${KERNEL_IMAGE:-/tmp/prp-qemu-vmlinuz}"
KERNEL_PACKAGE="linux"

# Monolithic: embed the overlay in the initramfs; no separate PRP_ROOTFS mount.
PRP_MONOLITHIC_INITRAMFS="1"
MOUNT_PRP_ROOTFS="0"
DO_MOUNT_SUBPARTS="0"

# Framebuffer GUI on QEMU's display (/dev/fb0 from bochs-drm / virtio-gpu).
ENABLE_FB_IO="1"
USE_FB_REFRESHER="0"
IS_MSM="0"
IS_MSM_FB_REFRESHER="0"

# A serial rescue shell on ttyS0 + console logging, so the VM is debuggable
# alongside the GUI (GUI owns fb0, shell owns ttyS0).
START_TTY_SHELLS="1"
TEXT_CONSOLE_LOG="1"
DEBUG_BOOT="0"
SMOKE_ONLY="0"
# No on-device debug/log partition on QEMU — skip the probe (avoids 8s stalls).
PROBE_DEBUG_PARTITION="0"

# No phone USB gadget / TWRP adb assets on QEMU.
USB_SERIAL="PRP-QEMU"
USB_GADGET_PATH=""
USB_UDC_NAME=""
REQUIRE_TWRP_SBIN="0"

FLASH_METHOD="qemu"
