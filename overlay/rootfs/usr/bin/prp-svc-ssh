#!/bin/sh
set -eu

PORT="${PRP_SSH_PORT:-2222}"
KEYDIR="${PRP_SSH_KEYDIR:-/etc/dropbear}"
HOSTKEY="${KEYDIR}/dropbear_rsa_host_key"
ALLOW_BLANK="${PRP_SSH_ALLOW_BLANK_PASSWORD:-1}"
FORCE_COMMAND="${PRP_SSH_FORCE_COMMAND:-}"

prp_ssh_log() {
  local msg="[prp-ssh] $*"
  printf '%s\n' "$msg" > /dev/kmsg 2>/dev/null || true
  printf '%s\n' "$msg" > /dev/console 2>/dev/null || true
  printf '%s\n' "$msg" > /dev/ttyS0 2>/dev/null || true
}

prp_set_sysctl() {
  local key="$1"
  local value="$2"
  local path="/proc/sys/${key//./\/}"
  if [ -w "$path" ]; then
    printf '%s\n' "$value" > "$path" 2>/dev/null || return 1
    return 0
  fi
  if command -v sysctl >/dev/null 2>&1; then
    sysctl -w "$key=$value" >/dev/null 2>&1 || return 1
    return 0
  fi
  return 1
}

prp_ssh_log "svc start port=$PORT blank=$ALLOW_BLANK"

mkdir -p /etc "$KEYDIR" /root/.ssh /var/run
mkdir -p /dev/pts /bin

if [ ! -s /root/.ssh/authorized_keys ] && [ -s "${KEYDIR}/authorized_keys" ]; then
  cp -f "${KEYDIR}/authorized_keys" /root/.ssh/authorized_keys 2>/dev/null || true
fi
chmod 0700 /root/.ssh 2>/dev/null || true
chmod 0600 /root/.ssh/authorized_keys 2>/dev/null || true
if [ -s /root/.ssh/authorized_keys ]; then
  prp_ssh_log "authorized_keys present"
else
  prp_ssh_log "authorized_keys missing"
fi

# Keep this standalone even when called from the GUI button directly.
shell_path="/usr/bin/prp-login-sh"
if [ "$ALLOW_BLANK" = "1" ]; then
  printf 'root::0:0:root:/root:%s\n' "$shell_path" > /etc/passwd
else
  printf 'root:x:0:0:root:/root:%s\n' "$shell_path" > /etc/passwd
fi
if [ ! -s /etc/group ]; then
  echo 'root:x:0:' > /etc/group
fi
prp_ssh_log "passwd shell=$shell_path"

# Dropbear checks shell validity against /etc/shells.
{
  echo /usr/bin/prp-login-sh
  echo /bin/sh
  echo /bin/ash
} > /etc/shells
prp_ssh_log "shells ready"

# Ensure an interactive shell is executable for SSH sessions.
if [ ! -x /bin/sh ] && [ -x /sbin/busybox ]; then
  ln -snf /sbin/busybox /bin/sh 2>/dev/null || true
fi
if [ -x /bin/sh ]; then
  prp_ssh_log "/bin/sh executable"
else
  prp_ssh_log "/bin/sh missing"
fi

# Ensure PTY infrastructure exists (needed for interactive ssh shell/tty).
if ! grep -q ' /dev/pts ' /proc/mounts 2>/dev/null; then
  mount -t devpts devpts /dev/pts >/dev/null 2>&1 || true
fi
if [ ! -e /dev/ptmx ]; then
  ln -snf /dev/pts/ptmx /dev/ptmx 2>/dev/null || mknod /dev/ptmx c 5 2 2>/dev/null || true
fi
prp_ssh_log "pty infra ready"

if [ ! -s "$HOSTKEY" ]; then
  prp_ssh_log "hostkey missing, generating"
  if [ -x /usr/sbin/dropbearkey ]; then
    /usr/sbin/dropbearkey -t rsa -s 2048 -f "$HOSTKEY" >/tmp/dropbearkey.log 2>&1 || true
  fi
fi
if [ ! -s "$HOSTKEY" ]; then
  prp_ssh_log "hostkey generation failed"
  echo "prp-svc-ssh: hostkey missing (see /tmp/dropbearkey.log)" >&2
  exit 1
fi
prp_ssh_log "hostkey ready"

if prp_set_sysctl net.ipv4.tcp_autocorking 0; then
  prp_ssh_log "sysctl tcp_autocorking=0"
else
  prp_ssh_log "sysctl tcp_autocorking failed"
fi

killall dropbear >/dev/null 2>&1 || true
args="-p $PORT -r $HOSTKEY"
if [ "$ALLOW_BLANK" = "1" ]; then
  # Allow password auth, and allow empty passwords (Dropbear -B).
  args="$args -B"
else
  # Key-only.
  args="$args -s"
fi
if [ -n "$FORCE_COMMAND" ]; then
  args="$args -c $FORCE_COMMAND"
  prp_ssh_log "force command=$FORCE_COMMAND"
fi
if [ "${PRP_SSH_FOREGROUND:-0}" = "1" ]; then
  args="$args -F"
fi
prp_ssh_log "exec dropbear args=$args"
echo "prp-svc-ssh: port=$PORT blank=$ALLOW_BLANK shell=$shell_path" >&2
exec /usr/sbin/dropbear $args
